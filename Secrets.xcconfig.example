// Copy this file to Secrets.xcconfig (gitignored, never committed) and fill in your own value.
// Register at https://developer.nytimes.com, create an app, enable Top Stories API.
// IMPORTANT: do NOT wrap the value in quotes — xcconfig does not strip them like
// shell/YAML does, so `NYT_API_KEY = "abc"` resolves to the literal 5-character
// string `"abc"` (quotes included), which NYT's API will reject with HTTP 401.
NYT_API_KEY = XXXXXXXX
